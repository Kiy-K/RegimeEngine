# ─────────────────────────────────────────────────────────────────────────── #
# GRAVITAS Engine — Environment Variables                                       #
# ─────────────────────────────────────────────────────────────────────────── #
#
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env
#
# The .env file is gitignored and will NOT be committed.

# Mistral AI API Key (for Eurasia + commentary)
# Get yours at: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=your-mistral-api-key-here

# Anthropic API Key (for Oceania + Winston)
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional: Weights & Biases (for RL training logging)
# WANDB_API_KEY=your-wandb-key-here
